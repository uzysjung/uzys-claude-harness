# Codex 프로젝트 설정 — {PROJECT_NAME}
# 위치: <project>/.codex/config.toml
# 생성: setup-harness.sh --cli=codex (Phase D)
#
# 참조:
# - docs/decisions/ADR-002-codex-hook-gap.md v2
# - docs/specs/codex-compat.md §3.4 OQ2 (trust entry 규약)
#
# 주의:
# - 프로젝트 스코프 hook은 사용자 ~/.codex/config.toml에 trust entry 등록 후에만 로드됨
# - `{...}` 플레이스홀더는 scripts/claude-to-codex.sh 에서 치환됨

# ============================================================
# Sandbox & Approval (파일 쓰기 보호 — ADR-002 v2 D3)
# ============================================================
approval_policy = "on-request"
sandbox_mode = "workspace-write"

[sandbox_workspace_write]
# 기본 쓰기 허용: 프로젝트 디렉토리 + /tmp
writable_roots = [
    "{PROJECT_DIR}",
    "/tmp",
]
network_access = true
# 민감 경로(.env, credentials, lock)는 AGENTS.md에 명시 — LLM 보조 방어

# ============================================================
# Model & Reasoning
# ============================================================
# model = "gpt-5-codex"                # 필요 시 활성화. 생략하면 기본값 사용
# model_reasoning_effort = "medium"

# ============================================================
# Analytics
# ============================================================
[analytics]
enabled = true

# ============================================================
# Hooks — Claude Code `.claude/settings.json` hooks 블록에서 포맷 변환
# Event 이벤트 매핑: ADR-002 v2 D2 / templates/codex/README.md
# ============================================================

# SessionStart: git pull + SPEC 재참조 안내
[[hooks.session_start]]
name = "session-start"
command = ["{PROJECT_DIR}/.codex/hooks/session-start.sh"]
type = "command"
timeout = 10
async = false

# UserPromptSubmit: HITO(Human-In-The-Loop Interrupts) 카운트
[[hooks.user_prompt_submit]]
name = "hito-counter"
command = ["{PROJECT_DIR}/.codex/hooks/hito-counter.sh"]
type = "command"
timeout = 5
async = true    # non-blocking 측정

# PreToolUse(Skill matcher): Phase 순서 강제 (exit 2로 차단)
# 주의: Issue #16732 — Bash 툴에만 발화. ApplyPatch(파일 쓰기)에는 fire 안 함
[[hooks.pre_tool_use]]
name = "gate-check"
command = ["{PROJECT_DIR}/.codex/hooks/gate-check.sh"]
type = "command"
timeout = 10
matcher = "Skill"
async = false

# PostToolUse: 미커밋 파일 경고 (Bash 한정)
[[hooks.post_tool_use]]
name = "uncommitted-check"
command = ["{PROJECT_DIR}/.codex/hooks/uncommitted-check.sh"]
type = "command"
timeout = 5
async = false

# ============================================================
# MCP Servers — .mcp.json에서 포맷 변환
# 조건부 포함: Track 따라 setup-harness가 추가
# ============================================================

[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]

# github MCP (필요 시 활성화)
# [mcp_servers.github]
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-github"]
# env = { GITHUB_PERSONAL_ACCESS_TOKEN = "{GITHUB_TOKEN}" }

# Railway MCP (csr-fastify/csr-fastapi/ssr-*/full 에서만)
# [mcp_servers.railway]
# command = "npx"
# args = ["-y", "railway-mcp-server"]

# ============================================================
# Features (본 설치가 사용하는 stable feature 명시)
# ============================================================
[features]
codex_hooks = true           # stable, 기본값 true — 명시적 확정
multi_agent = true           # stable — subagent SOD
plugins = true               # stable — plugin 번들 호환
tool_search = true           # stable
skill_mcp_dependency_install = true  # skill이 MCP 자동 설치
child_agents_md = false      # under dev — 본 SPEC 범위 밖
